# Amana Pay backend — انسخ هذا الملف إلى .env وعدّل القيم حسب الحاجة

# الخادم
PORT=4000
HOST=0.0.0.0
NODE_ENV=development

# قاعدة البيانات (SQLite)
# DB_FILE=./database/amana_pay.db

# JoPACC Open Finance
JOPACC_MODE=mock
JOPACC_GATEWAY_ROOT=https://jpcjofsdev.apigw-az-eu.webmethods.io/gateway
JOPACC_API_KEY=mock-gateway-api-key
JOPACC_BASIC_USER=mock-user
JOPACC_BASIC_PASS=mock-pass

# المطابقة والاستطلاع
POLL_INTERVAL_MS=15000
PAYMENT_EXPIRY_MS=1800000

# نموذج الربح
COMMISSION_RATE=0.01
FREE_TIER_MONTHLY=50

# الموافقة
CONSENT_VALIDITY_DAYS=90
