securitySchemes: 
    - 
        httpBasicAuth: 
            type: Basic Authentication
            describedBy: 
                headers: 
                    Authorization: 
                        type: string
                        required: false
                        repeat: false
        apiKey: 
            type: x-apiKey
            describedBy: 
                headers: 
                    Authorization: 
                        type: string
                        required: false
                        repeat: false
securedBy: 
    - 
        apiKey
    - 
        httpBasicAuth
/accounts/{accountId}/beneficiaries: 
    displayName: /accounts/{accountId}/beneficiaries
    get: 
        description: retrieve a list of beneficiaries
        headers: 
            Authorization: 
                description: Authorization header in which the token is placed
                type: string
                required: true
                repeat: false
            x-jws-signature: 
                description: JWS Signature, refer to security reference
                type: string
                required: true
                repeat: false
            x-customer-id: 
                description: Unique id for the User
                type: string
                required: false
                repeat: false
            x-customer-user-agent: 
                description: Indicates the user-agent the User is using. Helps protecting from comprimised devices
                type: string
                required: false
                repeat: false
            x-financial-id: 
                description: Unique id for the Financial Institution; BIC or Pseudo-BIC code of the sender
                type: string
                required: false
                repeat: false
            x-customer-ip-address: 
                description: The User's IP address if the user is currently logged in with the TPP
                type: string
                required: false
                repeat: false
            x-auth-date: 
                description: Date and time of the last authentication of the User by the TPP
                type: string
                required: false
                repeat: false
            x-interactions-id: 
                description: Unique id for the interaction, used in all request and responses that are related
                type: string
                required: true
                repeat: false
            x-idempotency-key: 
                description: Unique id that is generated for each request and response. Used for tracking and to check for duplicate calls
                type: string
                required: true
                repeat: false
        queryParameters: 
            beneficiaryType: 
                description: Beneficiary Type to inquire about
                type: string
                required: false
                repeat: false
            limit: 
                description: The maximum number of resources to return in the response. Used for pagination
                type: integer
                required: false
                repeat: false
                minimum: 1
                maximum: 1E+2
                default: 10
            skip: 
                description: The number of resources to skip showing in this response. Used for pagination
                type: integer
                required: false
                repeat: false
                default: 0
            sort: 
                description: Sorting the response by creation date of the resources (ascending or descending)
                type: string
                required: false
                repeat: false
                enum: [asc, desc]
                default: desc
        responses: 
            "200": 
                description: successful
                body: 
                    application/json: 
                        schema: beneficiaries
                        example: '{"data":[{"beneficiaryId":"str123","beneficiarytype":"charity","beneficiaryName":{"enName":"string","arName":"string","tradeName":{"enName":"string","arName":"string"}},"beneficiaryNickname":"SWG charity account","accountBasicInfo":{"accountId":"str123","mainRoute":{"schema":"IBAN","address":"JO27CBJO0010000000000000000001"}},"routings":[{"schema":"IBAN","address":"JO27CBJO0010000000000000000001"}],"endToEnd":"str123","notes":"free text","institutionBasicInfo":{"institutionType":"BANK","institutionIdentification":{"schema":"bicCode","address":"JORDJOA0"},"name":{"enName":"string","arName":"string","tradeName":{"enName":"string","arName":"string"}},"institutionPhoneNumber":"+962761231234"},"_links":{"self":{"href":"/accounts/{accountId}/beneficiaries/{beneficiaryId}","method":"GET"},"account":{"href":"/accounts/{accountId}","method":"GET"},"institution":{"href":"/institution","method":"GET"}}}],"links":{"next":{"href":"/{route}/{resource}?skip={X}&limit={Y}","method":"GET"},"prev":{"href":"/{route}/{resource}?skip={X}&limit={Y}","method":"GET"},"last":{"href":"/{route}/{resource}?skip={X}&limit={Y}","method":"GET"}}}'
            "400": 
                description: "400 Bad Request"
                body: 
                    application/json: 
                        schema: error_badRequest
                        example: '{"id":"2c8579d1-8ccb-49c1-b64d-ed2a5b357c8f","code":"http.request.invalid","desc":"Invalid request parameters","errors":[{"code":"http.headers.invalid","desc":"Required header x-interactions-id is missing"}]}'
            "401": 
                description: "401 Unauthorized"
                body: 
                    application/json: 
                        schema: error_unauthorized
                        example: |-
                            {"id":"2c8579d1-8ccb-49c1-b64d-ed2a5b357c8f","code":"http.auth.invalid","desc":"Invalid authentication credentials","errors":[{"code":"http.auth.header.missing","desc":"Authentication header is missing. Please include the 'Authorization' header in your request."}]}
            "500": 
                description: "500 Internal Service Error"
                body: 
                    application/json: 
                        schema: error_internalServerError
                        example: '{"id":"2c8579d1-8ccb-49c1-b64d-ed2a5b357c8f","code":"server.error","desc":"An internal server error occurred","errors":[{"code":"server.error.database","desc":"Error accessing the database. Please contact the development support team or try again later"}]}'
            "403": 
                description: "403 Forbidden"
                body: 
                    application/json: 
                        schema: error_forbidden
                        example: '{"id":"2c8579d1-8ccb-49c1-b64d-ed2a5b357c8f","code":"http.auth.forbidden","desc":"Insufficient privileges. Access to the requested resource is forbidden","errors":[{"code":"http.auth.role.insufficient","desc":"You do not have the necessary permissions to access this resource"}]}'
            "404": 
                description: "404 Not Found"
                body: 
                    application/json: 
                        schema: error_notFound
                        example: '{"id":"2c8579d1-8ccb-49c1-b64d-ed2a5b357c8f","code":"resource.notFound","desc":"The requested resource could not be found","errors":[{"code":"http.url.invalid.endpoint","desc":"The requested endpoint is not valid. Please check the url and try again"}]}'
            "415": 
                description: "415 Unsupported Media Type"
                body: 
                    application/json: 
                        schema: error_unsupportedMediaType
                        example: |-
                            {"id":"2c8579d1-8ccb-49c1-b64d-ed2a5b357c8f","code":"media.unsupportedEncoding","desc":"The requested media encoding is not supported","errors":[{"code":"media.unsupportedEncoding.appXml","desc":"The requested format 'application/xml' is not supported"}]}
            "503": 
                description: "503 Service Unavailable"
                body: 
                    application/json: 
                        schema: error_serviceUnavailable
                        example: '{"id":"2c8579d1-8ccb-49c1-b64d-ed2a5b357c8f","code":"server.service.error","desc":"The requested service is currently unavailable","errors":[{"code":"server.service.maintenance","desc":"The service is temporarily down for maintenance. Please try again later"}]}'
            "405": 
                description: "405 Method Not Allowed"
                body: 
                    application/json: 
                        schema: error_methodNotAllowed
                        example: '{"id":"2c8579d1-8ccb-49c1-b64d-ed2a5b357c8f","code":"http.method.invalid","desc":"The requested HTTP method is not allowed for this resource","errors":[{"code":"http.method.invalid.patch","desc":"PATCH method is not supported for this resource"}]}'
            "406": 
                description: "406 Not Acceptable"
                body: 
                    application/json: 
                        schema: error_notAcceptable
                        example: |-
                            {"id":"2c8579d1-8ccb-49c1-b64d-ed2a5b357c8f","code":"http.headers.invalid\"","desc":"The requested content cannot be served in the specified format","errors":[{"code":"http.content.unsupportedFormat","desc":"The requested format is not supported. Please specify a different format"}]}
            "429": 
                description: "429 Too Many Requests"
                body: 
                    application/json: 
                        schema: error_tooManyRequests
                        example: |-
                            {"id":"2c8579d1-8ccb-49c1-b64d-ed2a5b357c8f","code":"rateLimit.exceeded","desc":"The rate limit for requests has been exceeded","errors":[{"code":"rateLimit.exceeded","desc":"The maximum number of requests '500/min' has been reached. Try again in '53 seconds'"}]}
        baseUriParameters: 
            accountId: 
                description: Account id of the user
                type: string
                required: true
                repeat: false
    /{beneficiaryId}: 
