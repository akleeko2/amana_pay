    /{branchId}: 
        displayName: /institution/branches/{branchId}
        get: 
            description: retrieve branch information
            headers: 
                Authorization: 
                    description: Authorization header in which the token is placed
                    type: string
                    required: true
                    repeat: false
                x-jws-signature: 
                    description: JWS Signature, refer to security reference
                    type: string
                    required: true
                    repeat: false
                x-financial-id: 
                    description: Unique id for the Financial Institution; BIC or Pseudo-BIC code of the sender
                    type: string
                    required: false
                    repeat: false
                x-interactions-id: 
                    description: Unique id for the interaction, used in all request and responses that are related
                    type: string
                    required: true
                    repeat: false
                x-idempotency-key: 
                    description: Unique id that is generated for each request and response. Used for tracking and to check for duplicate calls
                    type: string
                    required: true
                    repeat: false
            responses: 
                "200": 
                    description: successful
                    body: 
                        application/json: 
                            schema: branch
                            example: '{"branchId":"str123","branchType":"fullService","branchInfo":{"name":{"enName":"string","arName":"string","tradeName":{"enName":"string","arName":"string"}},"address":{"addresslines":["Amman, Jordan","Wadi Saqra","Arar Street"],"city":"Amman","state":"Capital","postcode":"11962","countryInfo":{"countryCode":"JO","countryName":"Jordan"},"location":{"latitude":31.9504003,"longitude":35.8648691},"phoneNumber":"+962761231234","website":"www.jopacc.com","moreInfo":"textArea"}},"institutionBasicInfo":{"institutionType":"BANK","institutionIdentification":{"schema":"bicCode","address":"JORDJOA0"},"name":{"enName":"string","arName":"string","tradeName":{"enName":"string","arName":"string"}},"institutionPhoneNumber":"+962761231234"},"isAvailable":true,"workingHours":{"sunday":{"isWorkingDay":true,"openingTime":"10:00","closingTime":"18:00","secondOpeningTime":"19:00","secondClosingTime":"23:00"},"monday":{"isWorkingDay":true,"openingTime":"10:00","closingTime":"18:00","secondOpeningTime":"19:00","secondClosingTime":"23:00"},"tuesday":{"isWorkingDay":true,"openingTime":"10:00","closingTime":"18:00","secondOpeningTime":"19:00","secondClosingTime":"23:00"},"wednesday":{"isWorkingDay":true,"openingTime":"10:00","closingTime":"18:00","secondOpeningTime":"19:00","secondClosingTime":"23:00"},"thursday":{"isWorkingDay":true,"openingTime":"10:00","closingTime":"18:00","secondOpeningTime":"19:00","secondClosingTime":"23:00"},"friday":{"isWorkingDay":true,"openingTime":"10:00","closingTime":"18:00","secondOpeningTime":"19:00","secondClosingTime":"23:00"},"saturday":{"isWorkingDay":true,"openingTime":"10:00","closingTime":"18:00","secondOpeningTime":"19:00","secondClosingTime":"23:00"}},"hasAccessiblityFeatures":true,"accessibilityFeatures":["wheelchair","brailleSup"],"relatedSSTs":[{"sstId":"str123","type":"ATM","isAvailable":true,"access24HoursIndicator":true,"hasDepositCapability":true}],"routings":[{"schema":"IBAN","address":"JO27CBJO0010000000000000000001"}],"services":["accountOpening"],"attributes":["elite"],"notes":"textArea","_links":{"self":{"href":"/institution/branches/{branchId}","method":"GET"},"institution":{"href":"/institution","method":"GET"}}}'
                "400": 
                    description: "400 Bad Request"
                    body: 
                        application/json: 
                            schema: error_badRequest
                            example: '{"id":"2c8579d1-8ccb-49c1-b64d-ed2a5b357c8f","code":"http.request.invalid","desc":"Invalid request parameters","errors":[{"code":"http.headers.invalid","desc":"Required header x-interactions-id is missing"}]}'
