    /quote: 
        displayName: /institution/FXs/quote
        post: 
            description: create a quote request for a specific currency. This service acts as a quote calculator.
            headers: 
                Authorization: 
                    description: Authorization header in which the token is placed
                    type: string
                    required: true
                    repeat: false
                x-jws-signature: 
                    description: JWS Signature, refer to security reference
                    type: string
                    required: true
                    repeat: false
                x-financial-id: 
                    description: Unique id for the Financial Institution; BIC or Pseudo-BIC code of the sender
                    type: string
                    required: false
                    repeat: false
                x-interactions-id: 
                    description: Unique id for the interaction, used in all request and responses that are related
                    type: string
                    required: true
                    repeat: false
                x-idempotency-key: 
                    description: Unique id that is generated for each request and response. Used for tracking and to check for duplicate calls
                    type: string
                    required: true
                    repeat: false
            body: 
                application/json: 
                    schema: '{"required":["sourceAmount","sourceCurrency","targetCurrency"],"type":"object","properties":{"sourceAmount":{"type":"number","format":"float(4 decimals)","example":"100"},"sourceCurrency":{"type":"string","format":"ISO 4217","example":"JOD"},"targetCurrency":{"type":"string","format":"ISO 4217","example":"USD"}}}'
                    example: '{"sourceCurrency":"JOD","targetCurrency":"USD","sourceAmount":100}'
            responses: 
                "201": 
                    description: successful
                    body: 
                        application/json: 
                            schema: |-
                                {"required":["conversionValue","conversionValue","effectiveDate","effectiveDateTime","sourceCurrency","targetCurrency"],"type":"object","properties":{"conversionValue":{"type":"number","description":"The rate of converting the amount from the \"sourceCurrency\" to \"targetCurrency\"","format":"float","example":"1.41"},"effectiveDateTime":{"type":"string","description":"The start date and time when this FX rate becomes active","format":"date-time(YYYY-MM-DDTHH:mm:ssZ)","example":"2006-09-15T10:30:00Z"},"fee":{"required":["amount","currency"],"type":"object","properties":{"amount":{"type":"number","format":"float(4 decimals)","example":"25.001"},"currency":{"type":"string","format":"ISO 4217","example":"JOD"}}},"inverseConversionValue":{"type":"number","description":"The rate of converting the amount from the \"sourceCurrency\" to \"targetCurrency\"","format":"float","example":"0.709"},"lastEffectiveDateTime":{"type":"string","description":"The finish date and time when this FX rate no longer is valid or active","format":"date-time(YYYY-MM-DDTHH:mm:ssZ)","example":"2006-09-15T10:30:00Z"},"quoteId":{"type":"string","example":"str123"},"sourceAmount":{"type":"number","format":"float(4 decimals)","example":"100"},"sourceCurrency":{"type":"string","format":"ISO 4217","example":"JOD"},"targetAmount":{"type":"number","format":"float(4 decimals)","example":"141"},"targetCurrency":{"type":"string","format":"ISO 4217","example":"USD"}}}
                            example: '{"quoteId":"str123","sourceCurrency":"JOD","targetCurrency":"USD","conversionValue":1.41,"inverseConversionValue":0.709,"sourceAmount":100,"targetAmount":141,"fee":{"amount":25.001,"currency":"JOD"},"effectiveDateTime":"2006-09-15T10:30:00Z","lastEffectiveDateTime":"2006-09-15T10:30:00Z"}'
                "400": 
                    description: "400 Bad Request"
                    body: 
                        application/json: 
                            schema: '{"required":["code","desc","id"],"type":"object","properties":{"code":{"type":"string","example":"http.request.invalid"},"desc":{"type":"string","example":"Invalid request parameters"},"errors":{"type":"array","items":{"type":"object","properties":{"code":{"type":"string","example":"http.headers.invalid"},"desc":{"type":"string","example":"Required header x-interactions-id is missing"}}}},"id":{"type":"string","format":"UUIDv4","example":"2c8579d1-8ccb-49c1-b64d-ed2a5b357c8f"}}}'
                            example: '{"id":"2c8579d1-8ccb-49c1-b64d-ed2a5b357c8f","code":"http.request.invalid","desc":"Invalid request parameters","errors":[{"code":"http.headers.invalid","desc":"Required header x-interactions-id is missing"}]}'
