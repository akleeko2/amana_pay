    /{targetCurrency}: 
        displayName: /institution/FXs/{targetCurrency}
        get: 
            description: retrieve a specific currency's conversion data. The rate will be the conversion from the "sourceCurrency" header variable to the "targetCurrency" path variable
            headers: 
                Authorization: 
                    description: Authorization header in which the token is placed
                    type: string
                    required: true
                    repeat: false
                x-jws-signature: 
                    description: JWS Signature, refer to security reference
                    type: string
                    required: true
                    repeat: false
                x-financial-id: 
                    description: Unique id for the Financial Institution; BIC or Pseudo-BIC code of the sender
                    type: string
                    required: false
                    repeat: false
                x-interactions-id: 
                    description: Unique id for the interaction, used in all request and responses that are related
                    type: string
                    required: true
                    repeat: false
                x-idempotency-key: 
                    description: Unique id that is generated for each request and response. Used for tracking and to check for duplicate calls
                    type: string
                    required: true
                    repeat: false
                sourceCurrency: 
                    description: The currency code to convert from. The returned rate will be the conversion from this "sourceCurrency" header to the "targetCurrency" path variable
                    type: string
                    required: true
                    repeat: false
            responses: 
                "200": 
                    description: successful
                    body: 
                        application/json: 
                            schema: |-
                                {"required":["conversionValue","conversionValue","effectiveDate","effectiveDateTime","sourceCurrency","targetCurrency"],"type":"object","properties":{"_links":{"type":"object","properties":{"institution":{"type":"object","properties":{"href":{"type":"string","example":"/institution"},"method":{"type":"string","example":"GET"}}},"self":{"type":"object","properties":{"href":{"type":"string","example":"/institution/FXs/{targetCurrency}"},"method":{"type":"string","example":"GET"}}}}},"conversionValue":{"type":"number","description":"The rate of converting the amount from the \"sourceCurrency\" to \"targetCurrency\"","format":"float","example":"1.41"},"effectiveDateTime":{"type":"string","description":"The start date and time when this FX rate becomes active","format":"date-time(YYYY-MM-DDTHH:mm:ssZ)","example":"2006-09-15T10:30:00Z"},"inverseConversionValue":{"type":"number","description":"The rate of converting the amount from the \"sourceCurrency\" to \"targetCurrency\"","format":"float","example":"0.709"},"lastEffectiveDateTime":{"type":"string","description":"The finish date and time when this FX rate no longer is valid or active","format":"date-time(YYYY-MM-DDTHH:mm:ssZ)","example":"2006-09-15T10:30:00Z"},"maxconversionValue":{"type":"number","format":"float","example":"5000"},"minconversionValue":{"type":"number","format":"float","example":"5"},"sourceCurrency":{"type":"string","format":"ISO 4217","example":"JOD"},"targetCurrency":{"type":"string","format":"ISO 4217","example":"USD"}}}
                            example: '{"sourceCurrency":"JOD","targetCurrency":"USD","conversionValue":1.41,"inverseConversionValue":0.709,"effectiveDateTime":"2006-09-15T10:30:00Z","lastEffectiveDateTime":"2006-09-15T10:30:00Z","minconversionValue":5,"maxconversionValue":5000,"_links":{"self":{"href":"/institution/FXs/{targetCurrency}","method":"GET"},"institution":{"href":"/institution/","method":"GET"}}}'
                "400": 
                    description: "400 Bad Request"
                    body: 
                        application/json: 
                            schema: '{"required":["code","desc","id"],"type":"object","properties":{"code":{"type":"string","example":"http.request.invalid"},"desc":{"type":"string","example":"Invalid request parameters"},"errors":{"type":"array","items":{"type":"object","properties":{"code":{"type":"string","example":"http.headers.invalid"},"desc":{"type":"string","example":"Required header x-interactions-id is missing"}}}},"id":{"type":"string","format":"UUIDv4","example":"2c8579d1-8ccb-49c1-b64d-ed2a5b357c8f"}}}'
